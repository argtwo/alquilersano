# ── Base de datos ──────────────────────────────────────────────────────────────
# Dev local (docker compose up -d db)
DATABASE_URL=postgresql+asyncpg://alquiler:alquiler@localhost:5432/alquilersano
POSTGRES_USER=alquiler
POSTGRES_PASSWORD=alquiler
POSTGRES_DB=alquilersano

# Producción con docker-compose.prod.yml (backend accede al servicio "db" interno)
# DATABASE_URL=postgresql+asyncpg://alquiler:SECRETO@db:5432/alquilersano

# Producción en Render (usar la DATABASE_URL que proporciona Render en el dashboard)
# DATABASE_URL=postgresql+asyncpg://...render.com/alquilersano

# ── Backend ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=true

# Dev: solo el dev server de Vite
ALLOWED_ORIGINS=http://localhost:5173
# Producción: dominio real + Vercel preview
# ALLOWED_ORIGINS=https://alquilersano.es,https://alquilersano.vercel.app

# ── Frontend ───────────────────────────────────────────────────────────────────
# Dev: apunta directamente al backend local
VITE_API_URL=http://localhost:8000

# Producción con nginx proxy (docker-compose.prod.yml): dejar vacío → rutas relativas
# VITE_API_URL=

# Producción en Vercel (apunta al backend de Render):
# VITE_API_URL=https://alquilersano-backend.onrender.com
